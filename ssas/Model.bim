        "measures": [
          {
            "name": "Total Sales",
            "expression": " SUM(FactOrderItems[Price])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Total Freight",
            "expression": " SUM(FactOrderItems[FreightValue])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Total Payment Value",
            "expression": " SUM(FactOrderItems[PaymentValue])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          },
          {
            "name": "Total Orders",
            "expression": " DISTINCTCOUNT(FactOrderItems[OrderID])",
            "formatString": "0"
          },
          {
            "name": "Total Order Items",
            "expression": " COUNTROWS(FactOrderItems)",
            "formatString": "0"
          },
          {
            "name": "Average Delivery Days",
            "expression": " AVERAGE(FactOrderItems[DeliveryDays])",
            "formatString": "0.00"
          },
          {
            "name": "Average Order Value",
            "expression": " DIVIDE([Total Sales],[Total Orders])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
              }
            ]
          }
        ]
